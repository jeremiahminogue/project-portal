# Copy to .env.local and fill in.

# ---------- Supabase ----------
# Project URL: Supabase Dashboard -> Project Settings -> API -> Project URL
PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Existing Next-era names are still supported if already present:
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# anon public key: Supabase Dashboard -> Project Settings -> API -> anon public
PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
# Existing Next-era names are still supported if already present:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# service role key (server-only, never exposed to client)
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# ---------- Object storage (S3-compatible file storage) ----------
# Tigris names:
TIGRIS_ENDPOINT=https://t3.storage.dev
TIGRIS_ACCESS_KEY_ID=YOUR-TIGRIS-ACCESS-KEY
TIGRIS_SECRET_ACCESS_KEY=YOUR-TIGRIS-SECRET
TIGRIS_BUCKET=project-portal-files
TIGRIS_REGION=auto
# Cloudflare R2 names are also supported:
# R2_ENDPOINT=https://YOUR-ACCOUNT-ID.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=YOUR-R2-ACCESS-KEY
# R2_SECRET_ACCESS_KEY=YOUR-R2-SECRET
# R2_BUCKET=project-portal-files
# R2_REGION=auto

# ---------- Resend email ----------
RESEND_API_KEY=re_YOUR-RESEND-KEY
RESEND_FROM="Pueblo Electric Portal <portal@puebloelectrics.com>"

# ---------- App ----------
PUBLIC_SITE_URL=https://portal.puebloelectrics.com
# Local development without Supabase uses a mock signed-in admin by default.
# Set to false when you want local auth to behave like production.
PORTAL_MOCK_AUTH=true
# Optional: force mock auth locally even when Supabase env vars are present.
PORTAL_FORCE_MOCK_AUTH=false
# The legacy local super-admin password fallback is disabled unless this is true.
# Never enable this in Vercel production.
PORTAL_ENABLE_LOCAL_SUPERADMIN=false
PORTAL_LOCAL_AUTH_SECRET=replace-with-a-long-random-string
PORTAL_LOCAL_SUPERADMIN_PASSWORD=replace-with-a-strong-password

# ---------- OCR safety knobs ----------
PORTAL_OCR_INLINE_MAX_BYTES=15728640
PORTAL_OCR_TIMEOUT_MS=20000
