{
  "name": "project-portal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare-vite": "node ./scripts/patch-vite-realpath.mjs",
    "styles": "tailwindcss -i ./src/tailwind.css -o ./src/tailwind.generated.css",
    "dev": "node ./scripts/patch-vite-realpath.mjs && tailwindcss -i ./src/tailwind.css -o ./src/tailwind.generated.css && vite --host 0.0.0.0 --configLoader native",
    "build": "node ./scripts/patch-vite-realpath.mjs && tailwindcss -i ./src/tailwind.css -o ./src/tailwind.generated.css && vite build --configLoader native",
    "preview": "vite preview --host 0.0.0.0 --configLoader native",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "type-check": "svelte-kit sync && tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1038.0",
    "@aws-sdk/s3-request-presigner": "3.1038.0",
    "@embedpdf/snippet": "2.14.1",
    "@lucide/svelte": "1.11.0",
    "@napi-rs/canvas": "0.1.100",
    "@supabase/ssr": "0.10.2",
    "@supabase/supabase-js": "2.105.0",
    "pdfjs-dist": "5.7.284",
    "tesseract.js": "7.0.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "5.5.4",
    "@sveltejs/adapter-vercel": "6.3.3",
    "@sveltejs/kit": "2.58.0",
    "@sveltejs/vite-plugin-svelte": "7.0.0",
    "@tailwindcss/cli": "4.2.4",
    "@types/node": "25.6.0",
    "supabase": "2.95.5",
    "svelte": "5.55.5",
    "svelte-check": "4.4.6",
    "tailwindcss": "4.2.4",
    "typescript": "6.0.3",
    "vite": "8.0.10"
  },
  "overrides": {
    "@sveltejs/kit": {
      "cookie": "0.7.2"
    }
  }
}
